# MongoDB Atlas (Node.js + Mongoose — không dùng Spring Boot)
# Atlas → Database → Connect → Drivers → copy connection string, thay <password> và <dbname>
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/horse-racing?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
PORT=8080

# ZaloPay Sandbox — đăng ký tại https://docs.zalopay.vn
# Dùng sb-openapi.zalopay.vn để test với tiền ảo
ZALOPAY_APP_ID=2553
ZALOPAY_KEY1=PcY4iZIKFCIdgZvA6ueMcMHHUbRLYjPL
ZALOPAY_KEY2=kLtgPl8HHhfvMuDHPwKfgfsY4Ydm9eIz
ZALOPAY_CREATE_URL=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_QUERY_URL=https://sb-openapi.zalopay.vn/v2/query
# Callback phải là URL public (dùng ngrok khi dev local). Poll FE vẫn hoạt động nếu chưa có ngrok.
ZALOPAY_CALLBACK_URL=http://localhost:8080/api/v1/zalopay/callback
ZALOPAY_REDIRECT_URL=http://localhost:5173/admin/wallet

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
